                return Direction.FORWARDS;
            }
            @Override
            public void processNode(final Node node, final PhotonDesignData photonDesignData) {
                if (node instanceof NodeFIFO) {
                }
            }
            @Override
            public void end(final PhotonDesignData photonDesignData) {
            }
            
            @Override
            public ReprocessMode reProcessOnChange() {
                return ReprocessMode.NEVER;
            }
        }
        public void finalizeKernel(Kernel kernel)
        {
            //PhotonDesignData pdd = kernel.getPhotonDesignData();
            //pdd.getCompileManager().runGraphPass(new GraphPassRemoveFIFO());
        }
    }
    public static char[] charAdapter(Character[] l)
    {
        char[] res = new char[l.length];
        for (int i = 0; i < l.length; i++) res[i] = l[i];
        return res;
    }
    public static BigInteger factorial(BigInteger x) {
        return x.compareTo(BigInteger.ONE) <= 0 ? BigInteger.ONE : x.multiply(factorial(x.subtract(BigInteger.ONE)));
    }
    public static BigInteger choose(BigInteger n, BigInteger k) {
        return factorial(n).divide(factorial(n.subtract(k)).multiply(factorial(k)));
    }
    public static class MagicBinCoeff
    {
        public static class MagicDivision
        {
            BigInteger val;
            int shift;
            public MagicDivision(BigInteger val, int shift) {
                this.val = val; this.shift = shift;
            }
        }
        public static MagicDivision magicgu(BigInteger nmax, BigInteger d)
        {
            BigInteger nc = nmax.add(BigInteger.ONE).divide(d).multiply(d).subtract(BigInteger.ONE);
            int nbits = nmax.bitLength() - 2;
            for (int p = 0; p <= 2 * nbits; p++) {
                BigInteger twotop = BigInteger.ONE.shiftLeft(p);
                if (twotop.compareTo(nc.multiply(d.subtract(BigInteger.ONE).subtract(twotop.subtract(BigInteger.ONE).mod(d)))) > 0) {
                    BigInteger m = twotop.add(d).subtract(BigInteger.ONE).subtract(twotop.subtract(BigInteger.ONE).mod(d)).divide(d);
                    return new MagicDivision(m, p);
                }
            }
            return null;
        }
        public static class MagicInfo
        {
            BigInteger[] vals;
            int[] shifts; 
            int largestBinCoeffBits;
            int largestMpliedBinCoeffBits;
            int largestMagicNumBits;
            public MagicInfo(BigInteger[] vals, int[] shifts, int largestBinCoeffBits, int largestMpliedBinCoeffBits, int largestMagicNumBits) {
                this.vals = vals; this.shifts = shifts;
                this.largestBinCoeffBits = largestBinCoeffBits;
                this.largestMpliedBinCoeffBits = largestMpliedBinCoeffBits;
                this.largestMagicNumBits = largestMagicNumBits;
            } 
        }        
        public static MagicInfo get_bincoeff_magic(int dimension)
        {
            BigInteger dim = BigInteger.valueOf(dimension);
            BigInteger largestbincoeff = choose(dim, dim.shiftRight(1)).multiply(dim.shiftRight(1).add(BigInteger.ONE));
            MagicDivision[] objs = IntStream.range(1, dimension+1+1).mapToObj(d -> magicgu(largestbincoeff, BigInteger.valueOf(d))).toArray(MagicDivision[]::new);
            BigInteger[] vals = Arrays.stream(objs).map(x -> x.val).toArray(BigInteger[]::new);
            int[] shifts = Arrays.stream(objs).mapToInt(x -> x.shift).toArray();
            return new MagicInfo(vals, shifts, choose(dim, dim.shiftRight(1)).bitLength(), largestbincoeff.bitLength(),
                Arrays.stream(vals).mapToInt(x -> x.bitLength()).max().getAsInt());
        }
    }
    public InitializeColSumDFEKernel(final KernelParameters parameters, int rows, int cols, boolean dual, int basekernpow2, int initKerns, int kernNum, int maxdim, boolean useFloat, int loopLength) {
        super(parameters);
        addKernelFinalizer(new RemoveFIFOFinalizer());
        //int CEPipelining = getKernelConfig().optimization.getCEPipelining();
        //final int counterChainWrapPipeliningLimit = 4;
        //final int counterChainDelay = maxdim / counterChainWrapPipeliningLimit;
        DFEType IntType = dfeInt(64);
        DFEType dataTypeFix64 = useFloat ? dfeFloat(11, 53) : dfeFixOffset(64, -62, SignMode.TWOSCOMPLEMENT);
        DFEType dataTypeFixCommonAdd = useFloat ? dfeFloat(15, 64) : dfeFixOffset(65, -62, SignMode.TWOSCOMPLEMENT);
        DFEComplexType cplxFix64Type = new DFEComplexType(dataTypeFix64);
        DFEComplexType cplxFixCommonAddType = new DFEComplexType(dataTypeFixCommonAdd);
        DFEVectorType < DFEComplex > colSumType = new DFEVectorType < DFEComplex > (cplxFixCommonAddType, cols);
        DFEVectorType < DFEComplex > colTransferType = new DFEVectorType < DFEComplex > (useFloat ? cplxFixCommonAddType : cplxFix64Type, cols);
        
        int mplicityRows = rows - (basekernpow2 + (dual ? 1 : 0)) - 1;
        int bincoeffbits = maxdim == 40 ? 38 : 45;
        //int mulDelay = maxdim == 40 ? 8 : 9;

        //int bitsToAddressSum = MathUtils.bitsToAddress(mplicityRows);

        DFEVectorType < DFEVar > oneRowType = new DFEVectorType < DFEVar > (useFloat ? dataTypeFix64 : IntType, 2 * cols);
        DFEVectorType < DFEVar > oneRowFixType = new DFEVectorType < DFEVar > (useFloat ? dataTypeFixCommonAdd : dfeInt(64 + 1), 2 * cols);
        DFEVectorType < DFEVector < DFEVar >> allRowsType = new DFEVectorType < DFEVector < DFEVar >> (oneRowType, mplicityRows);
        //OffsetExpr loopLength = kernNum == 0 ? stream.makeOffsetAutoLoop("loopLength") : stream.makeOffsetParam("loopLength", 1, 1);

        int kerns = 1 << basekernpow2;
        DFEVar photonsm1 = io.scalarInput("photonsm1", dfeUInt(8)).cast(dfeUInt(6));
        DFEVar rowpowadj2 = constant.var(dfeUInt(64), basekernpow2 + (dual ? 1 : 0));
        DFEVar msizem1 = kernNum == 0 ? null : io.scalarInput("msizem1", dfeUInt(8)).cast(dfeUInt(6));
        //DFEVar rowsm1 = io.scalarInput("rowsm1", dfeUInt(8)).cast(dfeUInt(6));
        DFEVar isLocal = null;
        if (dual) isLocal = io.scalarInput("isLocal", dfeUInt(8)).cast(dfeBool());
      
        DFEVar ticksBeforeCols = io.scalarInput("changeCount", dfeUInt(64));
        DFEVar photonsm1cast = photonsm1.cast(dfeUInt(64));
        DFEVar ticksBeforeReset = ticksBeforeCols + Utility.smallConstMul(photonsm1cast, loopLength, this); //multiply by float loopLength==15 or fixed point loopLength==7
        DFEVar resetSignal = control.count.makeCounter(control.count.makeParams(64).withMax(ticksBeforeReset)).getCount() === 0;
        //64 bits, we don't care about precise maximum=(ticksBeforeCols+loopLength-1)/loopLength + photonsm1cast as either another scalar
        //or magic number division required (divide by 20 is divide by 4 then a multiplication to achieve unsigned divide by 5) so we use ticksBeforeReset and a resetSignal instead
        Count.Counter loopCounter = control.count.makeCounter(control.count.makeParams(Utility.bitlength(loopLength-1)).withMax(loopLength).withReset(resetSignal).withInc(1)); //5 bits
        DFEVar mainCount = control.count.makeCounter(control.count.makeParams(64).withMax(ticksBeforeReset).withReset(resetSignal).withEnable(loopCounter.getWrap()).withInc(1)).getCount(); //64 bits
        DFEVar loopCount = loopCounter.getCount();
        DFEVar isInit = mainCount <= photonsm1cast;
        DFEVar notIsInit = mainCount > photonsm1cast;
        DFEVar isCalc = mainCount >= photonsm1cast;
        DFEVar isInitGcode = mainCount <= rowpowadj2;
        DFEVar isInitMplicity = mainCount > rowpowadj2 & isInit;
        //if (kernNum == 0) debug.simPrintf("%d %d %d %d %d\n", ticksBeforeCols, ticksBeforeReset, mainCount, loopCount, resetSignal);
        DFEVar firstTick = mainCount === 0;
        DFEVar notFirstTick = kernNum == 0 ? null : mainCount !== 0;
        DFEVar needData = kernNum == 0 ? null : msizem1 >= (kernNum * maxdim / initKerns);
        DFEVar notNeedData = kernNum == 0 ? null : msizem1 < (kernNum * maxdim / initKerns);
        DFEVar startOfLoop = loopCount === 0;
        
        DFEVar mplicityWrap = dfeBool().newInstance(this);
        
        DFEVectorType < DFEVar > oneRowPackedType = new DFEVectorType < DFEVar > (useFloat ? dataTypeFix64 : IntType, 2 * cols+2);
        DFEVector<DFEVar> oneRowPacked = oneRowPackedType.newInstance(this);
        //DFEVar rowData = kernNum == 0 ? optimization.pipeline(isRowInit) : (isRowInit & needData);
        //needData & (isInitGcode | (isInitMplicity & (firstTick | stream.offset(mplicityWrap, -loopLength))))
        //needData & isInitGcode | needData & isInitMplicity & firstTick | needData & isInitMplicity & stream.offset(mplicityWrap, -loopLength))))
        //import itertools; def gen_truth_mux(f, sz): return [f(*prod) for prod in itertools.product(range(2), repeat=sz)]
        //gen_truth_mux(lambda a, b, c, d, e: a & (b | c & (d | e)), 5)
        //gen_truth_mux(lambda b, c, d, e: (b | c & (d | e)), 4)
        DFEVar rowData = kernNum == 0 ? isInitGcode.cat(isInitMplicity).cat(firstTick).cat(stream.offset(mplicityWrap, -loopLength)).reinterpret(dfeUInt(4)) >= 5 //0-4, 5-15
             : needData.cat(isInitGcode).cat(isInitMplicity).cat(firstTick).cat(stream.offset(mplicityWrap, -loopLength)).reinterpret(dfeUInt(5)) >= 21; // 0-20, 21-31
        //DFEVar isRowInit = isInitGcode | initLoop;
        //DFEVar startOfRowLoop = isRowInit & startOfLoop;
        //startOfLoop & (isInitGcode | isInitMplicity & prevMplicityWrap)
        //gen_truth_mux(lambda a, b, c, d: a & (b | c & d), 4)
        DFEVar startOfRowLoop = 
                startOfLoop.cat(isInitGcode).cat(isInitMplicity).cat(stream.offset(mplicityWrap, -loopLength)).reinterpret(dfeUInt(4)) >= 11; //0-10, 11-15
        
        oneRowPacked <== io.input("mappedInputMtx_Rows", oneRowPackedType, rowData);
        DFEVar curRowChangeIndex = oneRowPacked[2*cols].slice(0, 6).reinterpret(dfeUInt(6));
        DFEVar rowChangeIndex = dfeUInt(6).newInstance(this);
        rowChangeIndex <== startOfRowLoop ? curRowChangeIndex : stream.offset(rowChangeIndex, -1);
        //DFEVar[] mplicityCounter = counterWithInit(6, rowChangeIndex, constant.var(dfeBool(), 1), 1, constant.zero(dfeUInt(6)), initLoop, initLoop, loopLength, true, false, this);
        DFEVar[] mplicityCounter = Utility.makeCounterWithInitValue(6, rowChangeIndex, startOfLoop, 1, constant.zero(dfeUInt(6)), constant.var(dfeUInt(6), 1), startOfRowLoop, true, 1, this);
        //mplicityWrap <== mplicityCounter[1];
        DFEVar mplicityCount = dfeUInt(6).newInstance(this);
        mplicityCount <== startOfLoop ? mplicityCounter[0] : stream.offset(mplicityCount, -1);
        //willMplicityWrap <== mplicityCount === rowChangeIndex - 2; //will wrap in 2 loops...
        //DFEVar mplicityWrap = dfeBool().newInstance(this);
        mplicityWrap <== startOfLoop ? mplicityCounter[1] : stream.offset(mplicityWrap, -1);

        DFEVar prevMplicityWrap = firstTick ? constant.var(dfeBool(), 1) : stream.offset(mplicityWrap, -loopLength);

        DFEVar initLoop = isInitMplicity & prevMplicityWrap;
        //if (kernNum == 0) debug.simPrintf("%d %d %d %d %d %d %d %d\n", isInit, isCalc, initLoop, initCount, mainCount, loopCount); 
        DFEVector < DFEVar > oneRow = oneRowType.newInstance(this);
        DFEVar counterInit = dfeUInt(6).newInstance(this);
        DFEVar curdir = dfeBool().newInstance(this);

        //if (kernNum == 1) debug.simPrintf("%d %d %d %d %d\n", isRowInit, initCount, loopCount, prevMplicityWrap, initLoop);
        DFEVar readRow = kernNum == 0 ? startOfRowLoop : startOfRowLoop & needData;
        rowChangeIndex = kernNum == 0 ? rowChangeIndex : (needData ? rowChangeIndex : 1);
        
        oneRow <== readRow ? oneRowPacked.pack().slice(0, oneRowType.getTotalBits()).reinterpret(oneRowType) : stream.offset(oneRow, -1);
        DFEVar cInit = initLoop ? oneRowPacked[2*cols].slice(6, 6).reinterpret(dfeUInt(6)) : stream.offset(counterInit, -loopLength);
        DFEVar cDir = initLoop ? oneRowPacked[2*cols].slice(6 + 6, 1).reinterpret(dfeBool()) : stream.offset(curdir, -loopLength);
        DFEVar nextCounterInit = kernNum == 0 ? cInit : (needData ? cInit : 0);
        counterInit <== nextCounterInit;
        curdir <== kernNum == 0 ? cDir : (needData ? cDir : 1);
        DFEVar initBinCoeff = kernNum != 0 ? null : dfeUInt(bincoeffbits).newInstance(this);
        if (kernNum == 0) initBinCoeff <== rowData ? oneRowPacked[2*cols].slice(6 + 6 + 1, bincoeffbits).reinterpret(dfeUInt(bincoeffbits)) : stream.offset(initBinCoeff, -loopLength);
        
        DFEVar inpmp = rowChangeIndex + 1;
        
        //if (kernNum == 0 && !dual) debug.simPrintf("%d %d %d %d %d %KObj%\n", initCount, rowChangeIndex, counterInit, curdir, initBinCoeff, oneRow); 
        
        //oneRow <== io.input("mappedInputMtx_Rows", oneRowType, readRow);

        if (kernNum != 0) {
            DFEVar c0 = useFloat ? constant.var(dataTypeFix64, 0.0) : constant.zero(IntType),
                    c1 = useFloat ? constant.var(dataTypeFix64, 1.0) : constant.var(IntType, 1L << 62);
            List < DFEVector < DFEVar >> initChoices = new ArrayList < > ();
            initChoices.add(constant.zero(oneRowType));
            List<DFEVar> allOnes = new ArrayList<>(); 
            for (int i = 0; i < maxdim / initKerns; i++) {
                allOnes.add(c1); allOnes.add(c0);
            }
            initChoices.add(oneRowType.newInstance(this, allOnes));
            initChoices.add(oneRow);
            oneRow = control.oneHotMux(needData.cat(firstTick & notNeedData).cat(notFirstTick & notNeedData), initChoices);
        }
        
        //if (!dual && kernNum == 0) debug.simPrintf("%d %d %d %d %d %d\n", initCount, rowChangeIndex, startOfLoop, startOfRowLoop, mplicityCount, mplicityWrap);
        DFEVar initDirection = mplicityCount >= (curdir ? (rowChangeIndex - nextCounterInit) : nextCounterInit);
        DFEVar gcodeCounter = nextCounterInit.cast(dfeUInt(7)) + (curdir ? constant.zero(dfeUInt(7)) : inpmp.cast(dfeUInt(7)));
        DFEVector < DFEVector < DFEVar >> allRows = allRowsType.newInstance(this);
        DFEVar storeRowIndex = dfeUInt(6).newInstance(this);
        DFEVar prevStoreRowIdx = firstTick ? constant.zero(dfeUInt(6)) : stream.offset(storeRowIndex, -1);
        storeRowIndex <== prevStoreRowIdx + (initLoop & startOfLoop).cast(dfeUInt(6));
        storeRowIndex = Utility.oneHotEncode(storeRowIndex - 1, mplicityRows, 32, this).reinterpret(dfeUInt(mplicityRows));
        DFEVectorType<DFEVar> initOneHotType = new DFEVectorType<DFEVar>(dfeBool(), mplicityRows);
        DFEVar oneHotInit = startOfRowLoop ? storeRowIndex : 0;
        oneHotInit = optimization.pipeline(oneHotInit.slice(mplicityRows/2, mplicityRows - mplicityRows/2)).cat(optimization.pipeline(oneHotInit.slice(0, mplicityRows/2)));
        DFEVector<DFEVar> initOneHot = oneHotInit.reinterpret(initOneHotType);        
        DFEVector < DFEVar > onerow0 = optimization.pipeline(oneRow);
        DFEVector < DFEVar > onerow1 = optimization.pipeline(oneRow);
        for (int i = 0; i < mplicityRows; i++) {
            allRows[i] <== initOneHot[i] ? (i < mplicityRows/2 ? onerow0 : onerow1) : stream.offset(allRows[i], -1);
        }
        //if (kernNum == 0) debug.simPrintf("%d %d %d %d %d %d %d %d\n", mainCount, counterInit, gcodeCounter, inpmp, curdir, initDirection, mplicityCount, storeRowIndex);
        
        DFEVar oneHotInitMplicity = initLoop ? storeRowIndex : 0;
        oneHotInitMplicity = optimization.pipeline(oneHotInitMplicity.slice(mplicityRows/2, mplicityRows - mplicityRows/2)).cat(optimization.pipeline(oneHotInitMplicity.slice(0, mplicityRows/2)));
        DFEVector<DFEVar> initMplicity = optimization.pipeline(oneHotInitMplicity).reinterpret(initOneHotType);
        DFEVector<DFEVar> initMplicityDelay = optimization.pipeline(oneHotInitMplicity).reinterpret(initOneHotType);
        DFEVector<DFEVar> initMplicityDelay8 = optimization.pipeline(oneHotInitMplicity).reinterpret(initOneHotType);
        DFEVectorType<DFEVar> mplicityType = new DFEVectorType<DFEVar>(dfeUInt(6), mplicityRows);
        DFEVar[] rowChangeIndexFanout = Utility.parallelFanout(inpmp, mplicityRows, 32, this);
        DFEVector<DFEVar> rowChangeIndexFanned = new DFEVectorType<DFEVar>(dfeUInt(6), mplicityRows).newInstance(this);
        for (int i = 0; i < mplicityRows; i++) rowChangeIndexFanned[i] <== rowChangeIndexFanout[i < mplicityRows/2 ? 0 : 1];

        DFEVector<DFEVar> rowMultiplicities = mplicityType.newInstance(this);
        rowMultiplicities <== initMplicity ? rowChangeIndexFanned : stream.offset(rowMultiplicities, -1);

        List<DFEVector<DFEVar>> cpChain = Utility.counterChainWithInit(isCalc, rowMultiplicities, nextCounterInit, nextCounterInit+1, initMplicityDelay, 1, loopLength, kernNum == 0, this);
        DFEVector<DFEVar> cpInitGrayCode = cpChain[0];
        
        DFEVector<DFEVar> countersZero = cpInitGrayCode !== 0;
        DFEVar rowChangeMask = Bitops.trailing1Detect(countersZero.reinterpret(dfeUInt(mplicityRows)));
        rowChangeMask = rowChangeMask === 0 ? 1 : rowChangeMask;
        
        DFEVar changePos = isInit ? storeRowIndex : rowChangeMask;
               
        DFEVectorType<DFEVar> curMplicityType = new DFEVectorType<DFEVar>(dfeUInt(6+1), mplicityRows);
        DFEVector<DFEVar> curMultiplicities = curMplicityType.newInstance(this);
        DFEVar nextEnable = (rowChangeMask<<1)-1;
        nextEnable = optimization.pipeline(nextEnable.slice(mplicityRows/2, mplicityRows - mplicityRows/2)).cat(optimization.pipeline(nextEnable.slice(0, mplicityRows/2)));
        DFEVar[] nextRowIdxFanout = Utility.parallelFanout(notIsInit, mplicityRows, 32, this);
        DFEVar[] gcodeCounters = Utility.parallelFanout(gcodeCounter, mplicityRows, 32, this);
        DFEVar[] gcodeCountersPlusInc = Utility.parallelFanout(gcodeCounter+1, mplicityRows, 32, this);
        for (int i = 0; i < mplicityRows; i++) {
            curMultiplicities[i] <== Utility.makeCounterWithInitValue(7, rowMultiplicities[i].cast(dfeUInt(7))<<1, nextRowIdxFanout[i < mplicityRows/2 ? 0 : 1] & nextEnable.get(i), 1, gcodeCounters[i < mplicityRows/2 ? 0 : 1], gcodeCountersPlusInc[i < mplicityRows/2 ? 0 : 1], initMplicityDelay8[i], false, loopLength, this)[0];
            //curMultiplicitiesTest[i] <== counterWithInit(7, rowMultiplicities[i].cast(dfeUInt(7))<<1, optimization.pipeline(nextRowIdxFanout[i < mplicityRows/2 ? 0 : 1] & nextEnable.get(i)), 1, gcodeCounter, initMplicity[i], initMplicity[i], loopLength, false, false, this)[0];
            //curMultiplicities[i] <== control.count.makeCounter(control.count.makeParams(7).withMax((rowMultiplicities[i]+1).cast(dfeUInt(7))<<1).withEnable(nextRowIdxFanout[i < mplicityRows/2 ? 0 : 1] & nextEnable.get(i))).getCount();
        }
        //if (kernNum == 0 && !dual) debug.simPrintf(isCalc, "%d %KObj% %KObj%\n", mainCount, curMultiplicities, curMultiplicitiesTest);
        inpmp = Utility.oneHotMux32to64(changePos, rowMultiplicities.getElementsAsList(), 16, this).cast(dfeUInt(7))-1;
        DFEVar curmp = Utility.oneHotMux32to64(changePos, curMultiplicities.getElementsAsList(), 16, this);
        DFEVar changeValue = curmp < inpmp;
        
        //if (kernNum == 0) debug.simPrintf("%d %d %d\n", notIsInit, changePos, changeValue); 
        DFEVar changePosIsZero = changePos === 0;
        if (dual) changePosIsZero = isLocal & changePosIsZero;
        DFEVar isNeg = (changePosIsZero ^ changeValue) & notIsInit;
        DFEVar isNegEven = dual ? null : changeValue & notIsInit;
        DFEVar isMplicityNeg = isInitMplicity & initDirection;
        DFEVar[] negations = new DFEVar[kerns];
        DFEVector<DFEVar> initGcodeBits = new DFEVectorType<DFEVar>(dfeUInt(1+1+basekernpow2+(dual ? 1 : 0)), kerns).newInstance(this);
        for (int kern = 0; kern < kerns; kern++) {
            long gcode = (kern << 1) ^ kern; //000, 011, 110, 101, 00isLocal, 01~isLocal, 11isLocal, 10~isLocal
            DFEVar initGcode = dual ? constant.var(dfeUInt(1+basekernpow2), gcode >> 1).cat(((gcode & 1) != 0) ^ isLocal).cat(isLocal).reinterpret(dfeUInt(1+1+basekernpow2+(dual ? 1 : 0))) : constant.var(dfeUInt(1+1+basekernpow2), gcode);
            initGcodeBits[kern] <== firstTick ?
                initGcode.slice(1, 1+basekernpow2+(dual ? 1 : 0)).cat(constant.zero(dfeBool())).reinterpret(dfeUInt(1+1+basekernpow2+(dual ? 1 : 0))) :
                stream.offset(initGcodeBits[kern], -loopLength) >> 1;
            negations[kern] = (dual || ((kern & 1) != 0) ? isNeg : isNegEven) | initGcodeBits[kern].get(0).reinterpret(dfeBool()) | isMplicityNeg;
        }        
        
        DFEVar binCoeffOutput = null;
        if (kernNum == 0) { //now we need the next multiplicities
            //cpInitGrayCode = Utility.repeatPipeline(cpInitGrayCode, 7+(dual ? 1 : 0), this);
            countersZero = ~cpChain[1]; //cpInitGrayCode !== rowMultiplicities-1;
            rowChangeMask = Bitops.trailing1Detect(countersZero.reinterpret(dfeUInt(mplicityRows)));
            DFEVar rowIndex = rowChangeMask;
            inpmp = Utility.oneHotMux32to64(rowIndex, rowMultiplicities.getElementsAsList(), 16, this).cast(dfeUInt(7))-1;
            curmp = Utility.oneHotMux32to64(rowIndex, curMultiplicities.getElementsAsList(), 16, this)+(notIsInit & (rowIndex <= changePos)).cast(dfeUInt(7)); //curMultiplicities lags by 1 except on transition
            //curmp can never have just wrapped to 0 or inpmp+1 which is why adding is okay
            curmp = curmp === ((inpmp+1)<<1) ? constant.zero(dfeUInt(7)) : ((curmp === inpmp) ? curmp+1 : curmp);
            DFEVar initParities = io.scalarInput("initParities", dfeUInt(32)).cast(dfeUInt(loopLength));
            DFEVar parity = control.mux(loopCount, initParities.reinterpret(new DFEVectorType<DFEVar>(dfeBool(), loopLength)).getElementsAsList());
            //DFEVar parity = Utility.repeatPipeline((initParities >> loopCount).get(0), 4, this);
            DFEVar nextRowChangeIsNeg = curmp <= inpmp;
            //n=i+1, n=n-1, k=k<n ? n-1-k : k-n, k<n ? bc*k/(n-k+1) : bc*(n-k)/(k+1) -> k<n ? (n-1-k)/(n-1-(n-1-k)+1) : (n-1-(k-n))/(k-n+1)
            DFEVar num = (nextRowChangeIsNeg ? inpmp - curmp : (inpmp<<1) - curmp + 1).cast(dfeUInt(6));
            DFEVar denom = (nextRowChangeIsNeg ? curmp + 1 : curmp-inpmp).cast(dfeUInt(6))-1;
            //long mplierConsts[] = null;
            BigInteger mplierConsts[] = null;
            char shiftConsts[] = null;
            int maxbits = 0;
            MagicBinCoeff.MagicInfo mi = MagicBinCoeff.get_bincoeff_magic(maxdim);
            //System.out.println("Size: " + maxdim +  "  Largest bincoeff bits: " + mi.largestBinCoeffBits + "  Largest multiplied bincoeff bits: " + mi.largestMpliedBinCoeffBits + "  Largest magic number bits: " + mi.largestMagicNumBits + " " + Arrays.asList(mi.vals) + " " + Arrays.stream(mi.shifts).boxed().collect(Collectors.toList()));
            bincoeffbits = mi.largestBinCoeffBits;
            maxbits = mi.largestMpliedBinCoeffBits;
            mplierConsts = mi.vals; //Arrays.stream(mi.vals).mapToLong(x -> x.longValue()).toArray();
            shiftConsts = charAdapter(Arrays.stream(mi.shifts).mapToObj(x -> Character.valueOf((char)x)).toArray(Character[]::new));
            DFEVectorType<DFEVar> divisionMplierType = new DFEVectorType<DFEVar>(dfeUInt(maxbits+1), maxdim+1);
            DFEVector<DFEVar> magicDivisionMpliers = divisionMplierType.newInstance(this);
            HashMap<Character, Integer> shiftToIndex = new HashMap<>();
            List<DFEVar> shiftIndices = new ArrayList<>();
            for (int i = 0; i < maxdim+1; i++) {
                //magicDivisionMpliers[i] <== constant.var(dfeUInt(maxbits+1), mplierConsts[i]);
                magicDivisionMpliers[i] <== constant.var(dfeUInt(maxbits+1), new Bits(maxbits+1, String.format("%0" + ((maxbits+1+3)/4) + "X", mplierConsts[i])));
                if (!shiftToIndex.containsKey(shiftConsts[i]))
                    shiftToIndex.put(shiftConsts[i], shiftToIndex.size());
                shiftIndices.add(constant.var(dfeUInt(4), shiftToIndex.get(shiftConsts[i]))); //0-5 and 42-47 or 50-55 is 12 shifts, 4 bits to select
            }           
            DFEVar cur_multiplicity = dfeUInt(bincoeffbits).newInstance(this);
            DFEVar lastMultiplicity = isInit ? initBinCoeff : stream.offset(cur_multiplicity, -loopLength);
            DFEVar mplied = Utility.mulKaratsubaRectangularExact(lastMultiplicity, Utility.mulExact(num, Utility.mux32to64(denom, magicDivisionMpliers.getElementsAsList(), 4, this), maxbits+1+6, maxbits+1+6, this), bincoeffbits+maxbits+1+6, bincoeffbits+maxbits+1+6, this); //38 bits * 49 bits is 8 latency, 45 bits * 56 bits is 9 latency
            DFEVectorType<DFEVar> divisionShiftType = new DFEVectorType<DFEVar>(dfeUInt(bincoeffbits), shiftToIndex.size());
            DFEVar shiftIndex = Utility.mux32to64(denom, shiftIndices, 4, this);
            DFEVector<DFEVar> magicDivisionShifts = divisionShiftType.newInstance(this);
            for (Character shift : shiftToIndex.keySet()) {
                magicDivisionShifts[shiftToIndex.get(shift)] <== (mplied >> shift).cast(dfeUInt(bincoeffbits));
            }
            
            cur_multiplicity <== control.mux(shiftIndex, magicDivisionShifts.getElementsAsList());
            //debug.simPrintf(isCalc, "%d %d %d %d %d %d %d %d %d %KObj% %KObj% %KObj%\n", parity, lastMultiplicity, cur_multiplicity, rowIndex, rowChangeMask, curmp, inpmp, num, denom, rowMultiplicities, curMultiplicities, cpInitGrayCode);
            binCoeffOutput = (parity ^ mainCount.get(0) ^ photonsm1cast.get(0)).cat(lastMultiplicity).reinterpret(dfeUInt(1+bincoeffbits));
            //io.output("bincoeff", binCoeffOutput, dfeUInt(1+bincoeffbits), Utility.repeatPipeline(isCalc, 56, this));
        }       

        DFEVectorType < DFEVector < DFEComplex >> allKernsType = new DFEVectorType < DFEVector < DFEComplex >> (colSumType, kerns);
        DFEVector < DFEVector < DFEComplex >> allColSums = allKernsType.newInstance(this);

        //read row from input matrix
        //DFEVector < DFEVar > useRow = Utility.mux32to64(Utility.repeatPipeline(changePos, (dual ? 2 : 0), this), allRows.getElementsAsList(), 4, this);
        DFEVector < DFEVar > useRow = Utility.oneHotMuxVector32to64(changePos, allRows.getElementsAsList(), 16, this);

        DFEVector < DFEComplex > rowToAdd;
        if (useFloat) { //multiply by 2 by adding 1 to exponent if not 0, inf or NaN
            DFEVectorType<DFEVar> expType = new DFEVectorType<DFEVar>(dfeUInt(11), 2 * cols);
            DFEVector<DFEVar> exponent = useRow.slice(53-1, 11);
            DFEVectorType < DFEComplex > cplxRowType = new DFEVectorType < DFEComplex > (cplxFix64Type, cols);
            rowToAdd = (useRow.slice(63, 1).cat(exponent.reinterpret(expType) + (exponent !== 0 & exponent !== ((1<<11)-1)).cast(expType)).cat(useRow.slice(0, 53-1))).reinterpret(cplxRowType).cast(colSumType);
            //rowToAdd = useRow.reinterpret(cplxRowType).cast(colSumType) + useRow.reinterpret(cplxRowType).cast(colSumType); //* constant.var(dataTypeFixCommonAdd, 2.0);
        } else rowToAdd = useRow.cat(constant.var(dfeBool(), 0)).reinterpret(colSumType); //same row always changes in all kernels by design
        //rowToAdd = isInit ? Utility.repeatPipeline(oneRow, 3 + (useFloat ? 3 : 0), this).cast(oneRowFixType).reinterpret(colSumType) : rowToAdd;
        List<DFEVector<DFEComplex>> selRow = new ArrayList<>();
        selRow.add(oneRow.cast(oneRowFixType).reinterpret(colSumType));
        selRow.add(rowToAdd);
        rowToAdd = Utility.oneHotMuxVector32to64(notIsInit.cat(isInit), selRow, 16, this);
        DFEVector < DFEComplex > negRowToAdd = -rowToAdd;
        //update sum vector
        for (int kern = 0; kern < kerns; kern++) {
            DFEVector < DFEComplex > prevColmnSumVector = colSumType.newInstance(this);
            prevColmnSumVector <== optimization.pipeline(firstTick) ? constant.zero(colSumType) : stream.offset(allColSums[kern], -loopLength);
            allColSums[kern] <== prevColmnSumVector + (negations[kern] ? optimization.pipeline(negRowToAdd) : optimization.pipeline(rowToAdd));
        }
        //for float - mux=1 + float add=13, for fixed point - mux+add is optimized to conditional add=1
        //if (!dual) debug.simPrintf(ticksMax===4, "%d %d %d\n%KObj%\n%KObj%\n%KObj%\n%KObj%\n", kernNum, tickCount, msize, allColSums[0], allColSums[1], allColSums[2], allColSums[3]);
        for (int i = 0; i < kerns; i++) {
            if (kernNum == 0) {
                io.output("colSums" + i, binCoeffOutput.cat(allColSums[i].cast(colTransferType).reinterpret(dfeRawBits(colTransferType.getTotalBits()))), dfeRawBits(colTransferType.getTotalBits() + 1 + bincoeffbits), isCalc);
            } else {
                io.output("colSums" + i, allColSums[i].cast(colTransferType), colTransferType, isCalc);
            }
        }
    }

}
