                            pw.println("\tset_clock_uncertainty 0.2 -setup -hold [get_clocks]"); //get_clocks {mmcm_STREAM*}
                            //pw.println("\tset_clock_uncertainty 0.2 -from [get_clocks] -to [get_clocks]"); //200 picoseconds/0.2 nanoseconds
                            pw.println("\tphys_opt_design -directive AggressiveExplore");
                            pw.println("\tset_clock_uncertainty 0 -setup -hold [get_clocks]");
                            //pw.println("\tset_clock_uncertainty 0 -from [get_clocks] -to [get_clocks]");
                            pw.println("}");
                            pw.println("if {[get_property SLACK [get_timing_paths -setup]] < 0} {");
                            pw.println("\tphys_opt_design -directive AggressiveExplore");
                            pw.println("}");
                            pw.println("if {[get_property SLACK [get_timing_paths -setup]] < 0} {");
                            pw.println("\tphys_opt_design -directive AggressiveFanoutOpt");
                            pw.println("}");
                        }
