                    }
                } catch (IOException e) { throw new IllegalArgumentException("IO error writing " + tclFile); }
            }
            return super.runVivadoProcOnCluster(procSpec, s);
        }
    }
    public class CustomVivadoRoute extends VivadoRoute
    {
        public CustomVivadoRoute(final BuildManager buildManager, final VivadoImplementationStrategy vivadoImplementationStrategy, boolean skipCompileSynth)
        {
            super(buildManager, vivadoImplementationStrategy);
            if (skipCompileSynth) {
                buildManager.pushWorkingDir("xilinx_vivado");
                buildManager.pushWorkingDir("route");
                buildManager.addBuildFile(new BuildFilePowerReportImpl(buildManager, "com_maxeler_platform_max5_board_XilinxAlveoU250Top" + ".power.rpt", false));
                buildManager.addBuildFile(new BuildFileChecksumRam(buildManager, "com_maxeler_platform_max5_board_XilinxAlveoU250Top" + "_checksum.txt", false));
                buildManager.addBuildFile(new BuildFileBusSkewLog(buildManager, "com_maxeler_platform_max5_board_XilinxAlveoU250Top" + ".bus_skew.rpt", false));                
                buildManager.popWorkingDir();
                buildManager.popWorkingDir();
            }
        }
        protected ProcResult runVivadoProcOnCluster(final ProcSpec procSpec, final String s) {
            String cmd = procSpec.getCommand();
            String[] cmds = cmd.split(" ");
            String tclFile = "";
            for (int i = 0; i < cmds.length; i++) {
                if (cmds[i].equals("-source")) {
                    tclFile = cmds[i+1];
                    break;
                }
            }
            if (!tclFile.isEmpty()) {
                List<String> lines = new ArrayList<>(); 
                try (BufferedReader br = new BufferedReader(new FileReader(tclFile))) {      
                    String line;              
                    while ((line = br.readLine()) != null) {
                        lines.add(line);
                    }
                } catch (IOException e) { throw new IllegalArgumentException("IO error reading " + tclFile); }
                try (PrintWriter pw = new PrintWriter(tclFile)) {
                    for (int i = 0; i < lines.size(); i++) {
                        if (lines.get(i).equals("set_param route.enableHoldExpnBailout 1")) {
                            //pw.println("set preRoutes [get_nets -of [get_timing_paths -max_paths 25000 -slack_lesser_than 0]]");
                            //pw.println("lappend preRoutes [get_nets -of [get_timing_paths -hold -max_paths 25000 -slack_lesser_than 0]]");
                            //pw.println("set preRoutes [get_nets -hier clk_nobuf]");
                            //pw.println("lappend preRoutes [get_nets -hier -regexp .*photonstreamingblockadapterwithsm1_q]");
                            //pw.println("lappend preRoutes [get_nets -of_objects [get_cells -hier -regexp .*portablecomponentsupplier] -filter {BUS_NAME==\"E\"}]");
                            //pw.println("route_design -nets [get_nets $preRoutes] -auto_delay");
                            pw.println("set_param route.enableGlobalHoldIter 1");
                        } else if (lines.get(i).startsWith("route_design -directive")) {
                            lines.set(i, lines.get(i).replace(" Explore", " AggressiveExplore") + " -ultrathreads");
                        } else if (lines.get(i).equals("if {[get_property SLACK [get_timing_paths -setup]] >= 0 && [get_property SLACK [get_timing_paths -hold]] < 0} {")) {
                            pw.println("if {[get_property SLACK [get_timing_paths -setup]] < 0} {");
                            pw.println("\tphys_opt_design -tns_cleanup -slr_crossing_opt");
                            pw.println("}");
                        } else if (lines.get(i).equals("\tphys_opt_design -hold_fix")) {
                            lines.set(i, lines.get(i) + " -aggressive_hold_fix -sll_reg_hold_fix"); 
                        }
                        pw.println(lines.get(i));
                    }
                } catch (IOException e) { throw new IllegalArgumentException("IO error writing " + tclFile); }
            }
            return super.runVivadoProcOnCluster(procSpec, s);
        }
    }    
    public class CustomAlveoToolchain extends AlveoToolchain
    {
        private List<BuildPass> cachePasses;
        private boolean skipCompileSynth = false;
        public CustomAlveoToolchain(boolean skipCompileSynth) {
            this.skipCompileSynth = skipCompileSynth;
        }
        public List<BuildPass> getBuildPasses(final BuildManager buildManager, final ManagerConfiguration managerConfiguration)
        {
            if (cachePasses == null) {
                List<BuildPass> buildPasses = super.getBuildPasses(buildManager, managerConfiguration);
                if (skipCompileSynth) {
                    int fromSynth = IntStream.range(0, buildPasses.size()).filter(i -> buildPasses.get(i) instanceof VivadoSynth).findFirst().getAsInt();
                    int toImp = IntStream.range(0, buildPasses.size()).filter(i -> buildPasses.get(i) instanceof VivadoImplementation).findFirst().getAsInt();
                    buildPasses.subList(fromSynth, toImp).clear();
                }
                cachePasses = buildPasses;
            } else if (skipCompileSynth) {
                VivadoCacheManager.get(buildManager).copyFromPreviousBuild();
            }
            return cachePasses;
        }
        protected BuildPass getGenerateMaxFileBuildPass(final BuildManager buildManager) {
            return (BuildPass)new VivadoGenerateMaxFileXilinx(buildManager);
        }
        public VivadoImplPass getPlacePass(final BuildManager buildManager, final VivadoImplementationStrategy vivadoImplementationStrategy) {
            return new CustomVivadoPlace(buildManager, vivadoImplementationStrategy);
        }
        public VivadoImplPass getRoutePass(final BuildManager buildManager, final VivadoImplementationStrategy vivadoImplementationStrategy) {
            return new CustomVivadoRoute(buildManager, vivadoImplementationStrategy, skipCompileSynth);
        }        
    } 
    public void rebuildFromTimingMetImplementation(String implementationStrategyName)
    {
        //vivado -mode tcl / vivado -mode gui -> open_checkpoint /scratch/xilinx_vivado/implementation/*/xilinx_vivado/route/*.dcp
        //com.maxeler.platform.max5.toolchain.build.VivadoResourceUsage build_name build_dir SYNTH|PAR (SYNTH=preliminary, PAR=final)
        //com.maxeler.platform.max5.toolchain.build.VivadoResourceAnnotation build_name build_dir
        //com.maxeler.platform.max5.toolchain.build.VivadoToolchain -> IMPLEMENTATION + FULL_BUILD
        //com.maxeler.platform.max5.libs.manager.Max5ManagerBuildInternal -> realBuild (called by DFEManager)
        //com.maxeler.platform.max5.toolchain.cache.VivadoCacheManager -> addImplementationInfo(IMPLEMENTATION_STRATEGY_NAME, ROUTE_CHECKPOINT)
        
        //first remove all non-matching implementation strategies
        VivadoBuildConfiguration buildConf = ((VivadoBuildConfiguration)getManagerConfig().get(VivadoBuildConfiguration.class));
        if (!implementationStrategyName.isEmpty()) {
            Collection<VivadoImplementationStrategy> strats = buildConf.getImplementationStrategies();
            strats.removeIf(e -> !e.getName().equals(implementationStrategyName));
            buildConf.setImplementationStrategies(strats.stream().collect(Collectors.toCollection(ArrayList::new)));
        }
        
        //name is strangely a upper ASCII \u00d4 or in Java Unicode character "Ô" 
        List<Field> find = Arrays.stream(XilinxAlveoU250Board.class.getDeclaredFields()).filter(f -> Modifier.isPrivate(f.getModifiers()) && f.getType().equals(Toolchain.class)).collect(Collectors.toCollection(ArrayList::new));
        
        //limit the build to remove both COMPILE_ONLY and SYNTHESIS
        XilinxAlveoU250Board board = (XilinxAlveoU250Board)this.m_platform;
        CustomAlveoToolchain toolchain = new CustomAlveoToolchain(!implementationStrategyName.isEmpty());
        toolchain.getBuildPasses(this.getBuildManager(), this.getManagerConfig()); //setBuildLevel becomes read-only so cache for later
        try {
            Field fld = board.getClass().getDeclaredField(find.get(0).getName());
            fld.setAccessible(true);
            fld.set(board, toolchain);
            fld.setAccessible(false);
        } catch (NoSuchFieldException|IllegalAccessException e) {
            throw new IllegalArgumentException("Toolchain field not found or accessible");
        }
               
        //add implementation strategy checkpoint file hash to the VivadoCache 
        if (!implementationStrategyName.isEmpty()) {
            final Hasher hasher = new Hasher();
            //we are already in the "scratch" directory
            this.getBuildManager().pushWorkingDir("xilinx_vivado");
            this.getBuildManager().pushWorkingDir("implementation");
            this.getBuildManager().pushWorkingDir(implementationStrategyName);
            this.getBuildManager().pushWorkingDir("xilinx_vivado");
            this.getBuildManager().pushWorkingDir("route");
            hasher.append(new File(new BuildFilePostRouteDcp(this.getBuildManager(), "com_maxeler_platform_max5_board_XilinxAlveoU250Top" + "_post_route.dcp", false, implementationStrategyName).getAbsoluteName()));
            this.getBuildManager().popWorkingDir();
            this.getBuildManager().popWorkingDir();
            this.getBuildManager().popWorkingDir();
            this.getBuildManager().popWorkingDir();
            this.getBuildManager().popWorkingDir();
            final String hash = hasher.getHash();
            final VivadoCacheManager vivadoCacheManager = new VivadoCacheManager(this.m_buildManager); //VivadoCacheManager.get(this.m_buildManager);
            vivadoCacheManager.copyFromPreviousBuild();
            vivadoCacheManager.addImplementationInfo(implementationStrategyName, hash);
        }
    }

    public PermanentGlynnDFEManagerAlveoU250(PermanentGlynnEngineParameters params) {
        super(params);
        getBuildManager().setPlatform(new XilinxAlveoU250BoardCustomMux());
        setDefaultStreamClockFrequency(params.getFrequency());
        //getManagerConfig().setStreamClockFrequencyMHz(params.getFrequency()); //setDefaultStreamClockFrequency
        getManagerConfig().setDefaultStreamFifoDepth(512); //64 minimum, 512 is default, with 300/320MHz and 4 registers per crossing, the minimum moves to 128, might cause stalling if too low
        setup(this, params.dual(), params.isSim(), params.useFloat(), params.getFrequency(), params.getMaxDim());
    }

    public static void main(final String[] argv) {
        final PermanentGlynnEngineParameters params = new PermanentGlynnEngineParameters(argv);

        final PermanentGlynnDFEManagerAlveoU250 manager = new PermanentGlynnDFEManagerAlveoU250(params);
        BuildConfig conf = manager.getBuildConfig();

        boolean isProbe = false;
        conf.setOptimizationGoal(BuildConfig.OptimizationGoal.SPEED);
        conf.setBuildEffort(BuildConfig.Effort.HIGH);
        conf.setImplementationNearMissRetries(2);
        conf.setImplementationNearMissThreshold(100000); //0-1000000 are considered within threshold for build success on MAX5
                
        conf.setSynthesisStrategy(Utility.getHighPerfSynthStrategy()); //SynthesisStrategy.FLOW_PERF_OPTIMIZED_HIGH);

        //Inspect output timing scores and rank from best to worst
        conf.setImplementationStrategies(Utility.chooseImplementationStrategies(true, isProbe));
        conf.setParallelism(5);

        manager.createSlicInterface(PermanentGlynnDFEManager.interfaceDefault(params.dual(), params.isSim(), params.useFloat(), params.getMaxDim()));
        
        final String implementationStrategyName = "";
        //manager.getBuildManager().setParameter(MaxCompilerBuildConf.build.verbose_output, true);
        manager.getBuildManager().setParameter(MaxCompilerBuildConf.build.clean_build_directory, false); //problematic for successful builds, but failed builds which have a timing score will get deleted...can manually delete dcp checkpoint files instead
        manager.rebuildFromTimingMetImplementation(implementationStrategyName);
                    
        manager.build();
    }




}
