    public class CustomVivadoPlace extends VivadoPlace
    {
        public CustomVivadoPlace(final BuildManager buildManager, final VivadoImplementationStrategy vivadoImplementationStrategy)
        {
            super(buildManager, vivadoImplementationStrategy);
        }
        protected ProcResult runVivadoProcOnCluster(final ProcSpec procSpec, final String s) {
            String cmd = procSpec.getCommand();
            String[] cmds = cmd.split(" ");
            String tclFile = "";
            for (int i = 0; i < cmds.length; i++) {
                if (cmds[i].equals("-source")) {
                    tclFile = cmds[i+1];
                    break;
                }
            }
            if (!tclFile.isEmpty()) {
                List<String> lines = new ArrayList<>(); 
                try (BufferedReader br = new BufferedReader(new FileReader(tclFile))) {
                    String line;             
                    while ((line = br.readLine()) != null) {
                        lines.add(line);
                    }
                } catch (IOException e) { throw new IllegalArgumentException("IO error reading " + tclFile); }
                try (PrintWriter pw = new PrintWriter(tclFile)) {
                    for (int i = 0; i < lines.size(); i++) {
                        if (lines.get(i).startsWith("opt_design ")) {
                        } else if (lines.get(i).startsWith("place_design -directive")) {
                            //llength [get_clock_regions] == 128 == 8*16
                            //llength [get_sites -filter {SITE_TYPE==HPIOBDIFFINBUF}] == 384 == 4*96
                            //llength [get_sites -filter {SITE_TYPE==SLICEL}] == 117120 == 61*2*960
                            //llength [get_sites -filter {SITE_TYPE==SLICEM}] == 98880 == 103*960
                            //llength [get_sites -filter {NAME=~SLICE_X117Y*}] == 960 == 4*240 == 16*60
                            //length [get_sites -filter {SITE_TYPE==BUFGCE}] == 384 == 4*96 == 16*24
                            //foreach clock [get_clocks -regexp mmcm_.*] { report_property $clock }
                            //foreach cell [get_cells -hier -regexp .*gen_0.dff_rst -filter {PARENT=~.*max5maxelerosplatform}] { puts [report_property [get_timing_paths -from $cell -to [get_cells -hier -regexp .*max5maxelerosplatform -filter [concat "REF_NAME==BUFGCE && DONT_TOUCH==0 && PARENT==" [get_property PARENT [get_property PARENT $cell]]]]]]}
                            //pw.println("set_property LOC HPIOBDIFFINBUF_X0Y106 [get_cells IBUFDS_freerunClk_inst]");
                            //pw.println("set_property CLOCK_REGION [get_clock_regions X4Y4] [get_cells BUFG_freerunClk_inst]");
                            //pw.println("set clockGroups [get_cells -hier mmcm_instance -filter {PARENT=~StreamClock*_clock_gen_i}]");
                            //foreach net $clockGroups { if {[regexp StreamClock(.*?)_clock_gen_i/mmcm_instance $net NULL match]} { set krnlstrm [dict create]; set cells [get_cells -of_objects [get_nets -segments -of_objects [get_pins -of_objects $net -filter {REF_PIN_NAME == CLKOUT0}]] -filter {PRIMITIVE_LEVEL!~LEAF}]; foreach cell $cells { if {[regexp wrapper/wrapper_entity/(\[^\/\]*) $cell NULL match]} { dict set krnlstrm $match NULL } }; puts [llength $cells]; puts $krnlstrm } }
                            //pw.println("regexp X.Y(.) [get_property CLOCK_REGION [get_cells BUFG_freerunClk_inst]] NULL yloc");
                            //pw.println("foreach mmcm $clockGroups { if {[regexp StreamClock(.*?)_clock_gen_i/mmcm_instance $mmcm NULL match]} { set_property LOC [concat MMCM_X0Y[expr $match*4+3-$match-($match==0 ? 1 : 0)]] $mmcm } }");
                            //pw.println("foreach net $clockGroups { if {[regexp StreamClock(.*?)_clock_gen_i/mmcm_instance $net NULL match]} { set_property USER_CLOCK_ROOT [get_clock_regions [concat X4Y[expr $match*4+3-$match-($match==0 ? 1 : 0)]]] [get_nets -of_objects [get_pins -of_objects [get_cells -of_objects [get_nets -segments -of_objects [get_pins -of_objects $net -filter {REF_PIN_NAME == CLKOUT0}]] -filter {REF_NAME == BUFGCE}] -filter {REF_PIN_NAME == O}]]} }"); 
                            //pw.println("foreach net $clockGroups { set_property CLOCK_DELAY_GROUP [concat [get_property PARENT $net]_CGROUP] [get_nets -of_objects [get_pins -of_objects [get_cells -of_objects [get_nets -segments -of_objects [get_pins -of_objects $net -filter {REF_PIN_NAME == CLKOUT0}]] -filter {REF_NAME == BUFGCE}] -filter {REF_PIN_NAME == O}]]}"); 
                            //pw.println("foreach net $clockGroups { if {[regexp StreamClock(.*?)_clock_gen_i/mmcm_instance $net NULL match]} { set_property CLOCK_REGION [get_clock_regions [concat X4Y[expr $match*4+3-$match-($match==0 ? 1 : 0)]]] [get_cells -of_objects [get_nets -segments -of_objects [get_pins -of_objects $net -filter {REF_PIN_NAME == CLKOUT0}]] -filter {REF_NAME == BUFGCE}]} }");
                            //pw.println("foreach net $clockGroups { if {[regexp StreamClock(.*?)_clock_gen_i/mmcm_instance $net NULL match]} { set bufgce [get_cells -of_objects [get_nets -segments -of_objects [get_pins -of_objects $net -filter {REF_PIN_NAME == CLKOUT0}]] -filter {REF_NAME == BUFGCE}]; for { set i 0 } { $i < [llength $bufgce] } { incr i } { set_property LOC [concat BUFGCE_X0Y[expr $i+12+24*($match*4+3-$match-($match==0 ? 1 : 0))]] [lindex $bufgce $i] } } }");
