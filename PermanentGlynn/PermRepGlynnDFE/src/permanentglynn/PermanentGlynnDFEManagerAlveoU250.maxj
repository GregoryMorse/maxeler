                            //lines.set(i, lines.get(i) + " -ultrathreads"); //not in current Vivado version
                        } else if (lines.get(i).startsWith("phys_opt_design")) {
                            //pw.println("place_design -post_place_opt");
                        } else if (lines.get(i).startsWith("write_checkpoint")) {
